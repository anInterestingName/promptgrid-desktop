{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FangCun",
  "version": "0.1.0",
  "identifier": "com.promptgrid.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:tauri-ui",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FangCun - 方寸画境",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$DOCUMENT/**", "$PICTURE/**", "$DESKTOP/**", "$DOWNLOAD/**", "D:\\**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
